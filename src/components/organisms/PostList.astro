---
import EmptyState from '../molecules/EmptyState.astro';
import type { BlogPostEntry } from '../../utils/blog';
import {
	formatPostDate,
	getBlogTitleTransitionName,
	getReadingTimeMinutes,
	toTaxonomySlug,
} from '../../utils/blog';

interface Props {
	posts: BlogPostEntry[];
	emptyTitle?: string;
	emptyDescription?: string;
}

const {
	posts,
	emptyTitle = 'No blog posts yet.',
	emptyDescription = 'Published blog entries will appear here.',
} = Astro.props;
---

{
	posts.length > 0 ? (
		<ul class="m-0 list-none p-0">
			{posts.map((post) => (
				<li class="border-b border-site-rule">
					<div class="m-0 rounded-md px-3 py-4">
						<a
							class="group flex items-start justify-between gap-4 rounded-md pb-[0.35rem] no-underline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(var(--accent-rgb),0.45)] max-[720px]:block"
							href={`/blog/${post.id}/`}
							data-blog-title-transition-name={getBlogTitleTransitionName(post.id)}
						>
							<div class="min-w-0">
								<h4
									class="m-0 text-xl leading-[1.2] text-site-heading group-hover:text-site-text group-focus-visible:text-site-text max-[720px]:text-[1.08rem] max-[720px]:leading-[1.28]"
									data-blog-title-transition-title
								>
									{post.data.title}
								</h4>
								<p class="mt-[0.35rem] mb-0 leading-[1.5] text-site-muted max-[720px]:text-[0.92rem] max-[720px]:leading-[1.55]">
									{post.data.description}
								</p>
							</div>
							<span class="inline-flex flex-none items-center gap-[0.55rem] max-[720px]:mt-1">
								<time class="m-0 whitespace-nowrap text-site-muted max-[720px]:text-[0.85rem]" datetime={post.data.pubDate.toISOString()}>
									{post.data.category} / {formatPostDate(post.data.pubDate)}
								</time>
								<span
									class="size-[0.45rem] rotate-45 border-t-2 border-r-2 border-[rgba(var(--gray),0.78)]"
									aria-hidden="true"
								/>
							</span>
						</a>
						<ul
							class="mt-[0.4rem] flex list-none flex-wrap gap-[0.35rem] p-0 text-[0.78rem] leading-[1.45] text-site-muted"
							aria-label={`${post.data.title} metadata`}
						>
							<li>約{getReadingTimeMinutes(post.body)}分</li>
							{post.data.tags.map((tag) => (
								<li>
									<a
										class="inline-flex min-h-[1.45rem] items-center rounded-full border border-[rgba(var(--border),0.9)] px-[0.45rem] text-site-muted no-underline hover:border-[rgba(var(--accent-rgb),0.28)] hover:text-site-text focus-visible:border-[rgba(var(--accent-rgb),0.28)] focus-visible:text-site-text"
										href={`/tags/${toTaxonomySlug(tag)}/`}
									>
										{tag}
									</a>
								</li>
							))}
						</ul>
					</div>
				</li>
			))}
		</ul>
	) : (
		<EmptyState title={emptyTitle} description={emptyDescription} ariaLabel="No blog posts" />
	)
}

<script>
	(() => {
		if (!('onpagereveal' in window)) {
			return;
		}

		const clearActiveTitle = () => {
			document.querySelectorAll('[data-active-title-transition]').forEach((title) => {
				title.style.viewTransitionName = '';
				delete title.dataset.activeTitleTransition;
			});
		};

		document.querySelectorAll('[data-blog-title-transition-name]').forEach((link) => {
			link.addEventListener('click', (event) => {
				if (
					event.defaultPrevented ||
					event.button !== 0 ||
					event.metaKey ||
					event.ctrlKey ||
					event.shiftKey ||
					event.altKey
				) {
					return;
				}

				const title = link.querySelector('[data-blog-title-transition-title]');
				const transitionName = link.dataset.blogTitleTransitionName;

				if (!title || !transitionName) {
					return;
				}

				clearActiveTitle();
				title.style.viewTransitionName = transitionName;
				title.dataset.activeTitleTransition = 'true';
			});
		});

		window.addEventListener('pageshow', clearActiveTitle);
	})();
</script>
