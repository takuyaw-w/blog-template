---
import { Image } from 'astro:assets';
import { getProjectPath, getProjectTagPath, type ProjectEntry } from '../../utils/projects';
import EmptyState from '../molecules/EmptyState.astro';
import ProjectActionLink from '../molecules/ProjectActionLink.astro';

type Props = {
	projects: ProjectEntry[];
	emptyTitle?: string;
	emptyDescription?: string;
	variant?: 'masonry' | 'grid';
};

const {
	projects,
	emptyTitle = 'No projects yet.',
	emptyDescription = 'Published projects will appear here.',
	variant = 'masonry',
} = Astro.props;
const isSparse = projects.length <= 2;
const isMasonry = variant === 'masonry' && !isSparse;
---

{
	projects.length > 0 ? (
		<ul
			class:list={[
				'project-list m-0 list-none p-0',
				isSparse
					? 'grid justify-center gap-4 grid-cols-[repeat(auto-fit,minmax(min(100%,18rem),28rem))]'
					: isMasonry
						? '[columns:3_18rem] [column-gap:1rem] max-[1080px]:[columns:2_18rem] max-[720px]:[columns:1]'
						: 'grid grid-cols-3 gap-4 max-[1080px]:grid-cols-2 max-[720px]:grid-cols-1',
			]}
		>
			{projects.map((project) => (
				<li
					class:list={[
						'project inline-flex w-full min-w-0 break-inside-avoid flex-col rounded-lg border border-[rgba(var(--border),0.86)] bg-[rgba(var(--surface-strong),0.62)] p-0',
						isMasonry ? 'mb-4' : 'm-0',
					]}
				>
					<a
						class="flex min-w-0 flex-col no-underline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(var(--accent-rgb),0.45)]"
						href={getProjectPath(project.id)}
					>
						{project.data.heroImage && (
							<Image
								class="block aspect-video w-full rounded-t-[7px] object-cover"
								src={project.data.heroImage}
								alt={project.data.heroImageAlt ?? `${project.data.title} preview`}
								width={640}
								height={360}
								loading="lazy"
								decoding="async"
							/>
						)}
						<span class="flex min-w-0 flex-col p-4">
							<span class="m-0 text-[0.78rem] leading-[1.4] text-site-muted">
								{project.data.category} / {project.data.status} / {project.data.period}
							</span>
							<span class="mt-[0.35rem] flex items-start justify-between gap-3">
								<span class="m-0 text-[1.15rem] leading-[1.3] font-bold text-site-heading">{project.data.title}</span>
								<span
									class="mt-[0.35rem] size-[0.45rem] flex-none rotate-45 border-t-2 border-r-2 border-[rgba(var(--gray),0.78)]"
									aria-hidden="true"
								/>
							</span>
							<span class="mt-[0.55rem] block text-[0.92rem] leading-[1.55] text-site-text">
								{project.data.description}
							</span>
						</span>
					</a>
					{project.data.tags.length > 0 && (
						<ul class="m-0 flex list-none flex-wrap gap-2 px-4 pb-4" aria-label={`${project.data.title} tags`}>
							{project.data.tags.map((tag) => (
								<li>
									<a
										class="inline-flex rounded-full border border-site-rule px-2 py-[0.1rem] text-[0.85rem] leading-[1.6] text-site-muted no-underline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(var(--accent-rgb),0.45)]"
										href={getProjectTagPath(tag)}
									>
										{tag}
									</a>
								</li>
							))}
						</ul>
					)}
					{(project.data.url || project.data.repository) && (
						<div class:list={['flex flex-wrap gap-y-3 gap-x-4 px-4 pb-4', project.data.tags.length > 0 && 'pt-0']}>
							{project.data.url && <ProjectActionLink href={project.data.url} label="View project" />}
							{project.data.repository && <ProjectActionLink href={project.data.repository} label="Repository" />}
						</div>
					)}
				</li>
			))}
		</ul>
	) : (
		<EmptyState title={emptyTitle} description={emptyDescription} ariaLabel="No projects" />
	)
}
