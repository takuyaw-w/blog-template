---
import { SITE_TITLE } from '../../consts';
import HeaderLink from '../molecules/HeaderLink.astro';
import Icon from '../atoms/Icon.astro';
import { SOCIAL_LINKS } from '../../utils/social-links';
---

<header class="site-header group m-0 border-b border-[rgba(var(--border),0.72)] bg-site-surface-strong px-4">
	<nav
		class="mx-auto grid w-site-nav max-w-full grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center max-[720px]:grid-cols-[minmax(0,1fr)_auto] max-[720px]:gap-y-[0.65rem] max-[720px]:gap-x-4 max-[720px]:py-[0.6rem]"
		aria-label="Primary navigation"
	>
		<h2 class="m-0 text-base max-[720px]:col-start-1 max-[720px]:row-start-1 max-[720px]:min-w-0 max-[720px]:leading-[1.2]">
			<a
				class="block text-site-heading! no-underline transition-colors duration-200 [-webkit-tap-highlight-color:transparent] hover:text-site-heading! focus-visible:text-site-heading! active:text-site-heading! max-[720px]:break-anywhere"
				href="/"
			>
				{SITE_TITLE}
			</a>
		</h2>
		<div
			id="primary-navigation"
			class="internal-links relative isolate flex items-center justify-self-center max-[720px]:col-span-full max-[720px]:row-start-2 max-[720px]:-mx-4 max-[720px]:hidden max-[720px]:w-[calc(100%+2rem)] max-[720px]:flex-col max-[720px]:items-stretch max-[720px]:gap-0 max-[720px]:border-t max-[720px]:border-[rgba(var(--border),0.8)] max-[720px]:px-4 max-[720px]:pt-1 group-data-[menu-open=true]:max-[720px]:flex [&>a:last-child]:max-[720px]:border-b-0"
		>
			<HeaderLink href="/">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="flex justify-self-end gap-1 max-[720px]:col-start-2 max-[720px]:row-start-1 max-[720px]:justify-end">
			<div class="flex items-center">
				<button
					class="theme-toggle inline-flex size-9 cursor-pointer items-center justify-center rounded-full border border-site-border bg-site-surface-soft text-site-heading hover:text-site-accent"
					type="button"
					aria-label="Toggle color theme"
					title="Toggle color theme"
				>
					<Icon name="sun" class="[html[data-theme='dark']_&]:hidden" size={20} />
					<Icon name="moon" class="hidden [html[data-theme='dark']_&]:block" size={20} />
				</button>
				{
					SOCIAL_LINKS.map((link) => (
						<a class="flex items-center px-2 py-4 text-site-heading no-underline max-[720px]:hidden" href={link.href} target="_blank" rel="noopener noreferrer">
							<span class="sr-only">{link.label}</span>
							<Icon name={link.icon} size={32} />
						</a>
					))
				}
			</div>
			<button
				class="menu-toggle relative hidden size-10 cursor-pointer items-center justify-center rounded-full border border-site-border bg-site-surface-soft text-site-heading hover:text-site-accent max-[720px]:inline-flex"
				type="button"
				aria-controls="primary-navigation"
				aria-expanded="false"
				aria-label="Open navigation menu"
			>
				<span
					class="absolute h-0.5 w-[1.05rem] -translate-y-[0.36rem] rounded-full bg-current transition-[opacity,transform] duration-200 group-data-[menu-open=true]:translate-y-0 group-data-[menu-open=true]:rotate-45"
				></span>
				<span
					class="absolute h-0.5 w-[1.05rem] rounded-full bg-current transition-[opacity,transform] duration-200 group-data-[menu-open=true]:opacity-0"
				></span>
				<span
					class="absolute h-0.5 w-[1.05rem] translate-y-[0.36rem] rounded-full bg-current transition-[opacity,transform] duration-200 group-data-[menu-open=true]:translate-y-0 group-data-[menu-open=true]:-rotate-45"
				></span>
			</button>
		</div>
	</nav>
</header>
<script>
	(() => {
		const initNavigationMenu = () => {
			document.querySelectorAll('.site-header').forEach((header) => {
				const toggle = header.querySelector('.menu-toggle');
				const menu = header.querySelector('.internal-links');

				if (!toggle || !menu || header.dataset.menuInitialized === 'true') {
					return;
				}

				header.dataset.menuInitialized = 'true';
				const setOpen = (isOpen) => {
					header.dataset.menuOpen = String(isOpen);
					toggle.setAttribute('aria-expanded', String(isOpen));
					toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
				};

				setOpen(false);
				toggle.addEventListener('click', () => {
					setOpen(header.dataset.menuOpen !== 'true');
				});
				menu.querySelectorAll('a').forEach((link) => {
					link.addEventListener('click', () => setOpen(false));
				});
				document.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') {
						setOpen(false);
					}
				});
			});
		};
		const initThemeToggle = () => {
			document.querySelectorAll('.theme-toggle').forEach((button) => {
				button.onclick = () => {
					const currentTheme = window.__getTheme?.() || document.documentElement.dataset.theme || 'light';
					const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';

					if (window.__setTheme) {
						window.__setTheme(nextTheme);
					} else {
						document.documentElement.dataset.theme = nextTheme;
					}
				};
			});
		};

		initNavigationMenu();
		initThemeToggle();
	})();
</script>
