---
import Icon from '../atoms/Icon.astro';
import { SOCIAL_LINKS } from '../../utils/social-links';
---

<footer class="site-footer bg-site-surface px-4 pt-9 pb-20 text-center text-site-muted">
	<div class="mx-auto w-site-footer max-w-full border-t border-site-border-soft pt-6">
		<nav
			class="grid grid-cols-[minmax(160px,auto)_repeat(2,auto)] items-start justify-between gap-y-5 gap-x-10 text-left max-[520px]:grid-cols-3 max-[520px]:gap-3 max-[520px]:text-[0.85rem]"
			aria-label="Footer navigation"
		>
			<div class="footer-group">
				<a class="font-bold text-site-text no-underline hover:text-site-text" href="/blog/">Blog</a>
				<ul class="mt-[0.35rem] grid list-none gap-1 p-0">
					<li><a class="text-site-muted no-underline hover:text-site-text" href="/categories/">Categories</a></li>
					<li><a class="text-site-muted no-underline hover:text-site-text" href="/tags/">Tags</a></li>
					<li><a class="text-site-muted no-underline hover:text-site-text" href="/years/">Years</a></li>
				</ul>
			</div>
			<div class="footer-group">
				<a class="font-bold text-site-text no-underline hover:text-site-text" href="/projects/">Projects</a>
				<ul class="mt-[0.35rem] grid list-none gap-1 p-0">
					<li>
						<a class="text-site-muted no-underline hover:text-site-text" href="/projects/categories/">Categories</a>
					</li>
					<li><a class="text-site-muted no-underline hover:text-site-text" href="/projects/tags/">Tags</a></li>
				</ul>
			</div>
			<div class="footer-group">
				<a class="font-bold text-site-text no-underline hover:text-site-text" href="/about/">Site</a>
				<ul class="mt-[0.35rem] grid list-none gap-1 p-0">
					<li><a class="text-site-muted no-underline hover:text-site-text" href="/about/">About</a></li>
				</ul>
			</div>
		</nav>
		<div class="mt-4 flex justify-center gap-4">
			{
				SOCIAL_LINKS.map((link) => (
					<a class="text-site-muted no-underline hover:text-site-text" href={link.href} target="_blank" rel="noopener noreferrer">
						<span class="sr-only">{link.label}</span>
						<Icon name={link.icon} size={32} />
					</a>
				))
			}
			<a class="text-site-muted no-underline hover:text-site-text" href="/rss.xml">
				<span class="sr-only">Subscribe to the RSS feed</span>
				<Icon name="rss" size={32} />
			</a>
		</div>
	</div>
</footer>
