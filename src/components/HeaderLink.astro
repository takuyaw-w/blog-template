---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (path: string) => {
	const normalized = path.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '');
	return normalized === '' ? '/' : normalized;
};
const pathname = normalizePath(Astro.url.pathname);
const normalizedHref = normalizePath(href?.toString() ?? '/');
const [primarySection] = pathname.match(/[^/]+/g) ?? [];
const blogSections = new Set(['blog', 'categories', 'tags', 'years']);
const isBlogPath = pathname === '/' || (primarySection !== undefined && blogSections.has(primarySection));
const isActive =
	normalizedHref === pathname ||
	(normalizedHref === '/' && isBlogPath) ||
	normalizedHref === `/${primarySection ?? ''}`;
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		padding: 1em 0.5em;
		border-bottom: 4px solid transparent;
		color: rgb(var(--black));
		text-decoration: none;
	}
	a:focus-visible {
		outline: 2px solid rgba(var(--accent-rgb), 0.45);
		outline-offset: 4px;
	}
	a.active {
		border-bottom-color: var(--accent);
		font-weight: bolder;
		text-decoration: none;
	}
	@media (max-width: 720px) {
		a {
			display: flex;
			align-items: center;
			box-sizing: border-box;
			width: 100%;
			min-height: 2.75rem;
			padding: 0.55rem 0.25rem;
			border-bottom: 1px solid rgba(var(--border), 0.68);
			border-radius: 0;
		}
		a:focus-visible {
			outline-offset: 2px;
		}
		a.active {
			border-bottom-color: rgba(var(--border), 0.68);
			color: var(--accent);
		}
	}
</style>
