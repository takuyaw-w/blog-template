---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (path: string) => {
	const normalized = path.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '');
	return normalized === '' ? '/' : normalized;
};
const pathname = normalizePath(Astro.url.pathname);
const normalizedHref = normalizePath(href?.toString() ?? '/');
const [primarySection] = pathname.match(/[^/]+/g) ?? [];
const blogSections = new Set(['blog', 'categories', 'tags', 'years']);
const isBlogPath = pathname === '/' || (primarySection !== undefined && blogSections.has(primarySection));
const isActive =
	normalizedHref === pathname ||
	(normalizedHref === '/' && isBlogPath) ||
	normalizedHref === `/${primarySection ?? ''}`;
---

<a
	href={href}
	class:list={[
		className,
		'inline-block border-b-4 border-transparent px-2 py-4 text-site-heading no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[rgba(var(--accent-rgb),0.45)] max-[720px]:flex max-[720px]:min-h-11 max-[720px]:w-full max-[720px]:items-center max-[720px]:box-border max-[720px]:rounded-none max-[720px]:border-b max-[720px]:border-[rgba(var(--border),0.68)] max-[720px]:px-1 max-[720px]:py-[0.55rem] max-[720px]:focus-visible:outline-offset-2',
		isActive && 'border-site-accent font-bold no-underline max-[720px]:border-[rgba(var(--border),0.68)] max-[720px]:text-site-accent',
	]}
	{...props}
>
	<slot />
</a>
