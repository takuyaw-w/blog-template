---
interface Props {
	href: string;
	label?: string;
	spacing?: 'normal' | 'loose';
}

const { href, label = 'Back', spacing = 'normal' } = Astro.props;
---

<a
	class:list={[
		'inline-flex text-[0.95rem] text-site-muted no-underline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(var(--accent-rgb),0.45)]',
		spacing === 'loose' ? 'mb-8' : 'mb-6',
	]}
	href={href}
	data-history-back
>
	{label}
</a>
<script>
	import { bindHistoryBackLinks } from '../../utils/history-back';

	bindHistoryBackLinks();
</script>
