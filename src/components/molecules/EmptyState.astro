---
interface Props {
	title: string;
	description?: string;
	ariaLabel?: string;
}

const { title, description, ariaLabel } = Astro.props;
---

<section class="empty-state" aria-label={ariaLabel}>
	<h2>{title}</h2>
	{description && <p>{description}</p>}
</section>

<style>
	.empty-state {
		padding: 3rem 0.75rem;
		border-top: 1px solid rgb(var(--gray-light));
		border-bottom: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
	}
	.empty-state h2 {
		margin: 0;
		color: rgb(var(--black));
		font-size: 1.25rem;
		line-height: 1.3;
	}
	.empty-state p {
		margin: 0.5rem 0 0;
		line-height: 1.6;
	}
</style>
