---
interface Props {
	title: string;
	description?: string;
	ariaLabel?: string;
}

const { title, description, ariaLabel } = Astro.props;
---

<section class="border-y border-site-rule px-3 py-12 text-site-muted" aria-label={ariaLabel}>
	<h2 class="m-0 text-xl leading-[1.3] text-site-heading">{title}</h2>
	{description && <p class="mt-2 mb-0 leading-[1.6]">{description}</p>}
</section>
