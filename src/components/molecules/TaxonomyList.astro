---
import EmptyState from './EmptyState.astro';

interface Props {
	items: [name: string, count: number][];
	basePath: string;
	emptyTitle?: string;
	emptyDescription?: string;
}

const {
	items,
	basePath,
	emptyTitle = 'No items yet.',
	emptyDescription = 'Items will appear here once content is published.',
} = Astro.props;
---

{
	items.length > 0 ? (
		<ul class="m-0 list-none p-0">
			{items.map(([name, count]) => (
				<li class="border-b border-site-rule">
					<a
						class="flex items-baseline justify-between rounded-md px-3 py-4 text-site-heading no-underline transition-colors duration-200 hover:bg-[rgba(var(--gray-light),0.45)]"
						href={`${basePath}/${encodeURIComponent(name)}/`}
					>
						<span>{name}</span>
						<span class="text-[0.9rem] text-site-muted">{count}</span>
					</a>
				</li>
			))}
		</ul>
	) : (
		<EmptyState title={emptyTitle} description={emptyDescription} ariaLabel="No taxonomy items" />
	)
}
