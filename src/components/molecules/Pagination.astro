---
import { getPageNumbers } from '../../utils/blog';

interface Props {
	currentPage: number;
	totalPages: number;
	basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const normalizeBasePath = (path: string) => (path === '/' ? '' : path.replace(/\/$/, ''));
const base = normalizeBasePath(basePath);
const getPageUrl = (page: number) => (page === 1 ? (base ? `${base}/` : '/') : `${base}/page/${page}/`);
const pages = getPageNumbers(totalPages);
---

{
	totalPages > 1 && (
		<nav class="mt-8 flex items-center justify-between gap-4 max-[720px]:block" aria-label="Pagination">
			<a
				class:list={[
					'inline-flex min-h-9 min-w-9 items-center justify-center rounded-md border border-site-border px-[0.65rem] py-[0.35rem] text-[0.9rem] text-site-text no-underline transition-colors duration-200 hover:border-[rgba(var(--accent-rgb),0.45)] hover:bg-[rgba(var(--accent-rgb),0.08)] hover:text-site-heading max-[720px]:w-full',
					currentPage === 1 && 'pointer-events-none opacity-45',
				]}
				href={currentPage === 1 ? undefined : getPageUrl(currentPage - 1)}
				aria-disabled={currentPage === 1 ? 'true' : undefined}
			>
				Prev
			</a>
			<div class="flex flex-wrap justify-center gap-[0.4rem] max-[720px]:my-3">
				{pages.map((page) => (
					<a
						class:list={[
							'inline-flex min-h-9 min-w-9 items-center justify-center rounded-md border border-site-border px-[0.65rem] py-[0.35rem] text-[0.9rem] text-site-text no-underline transition-colors duration-200 hover:border-[rgba(var(--accent-rgb),0.45)] hover:bg-[rgba(var(--accent-rgb),0.08)] hover:text-site-heading',
							page === currentPage && 'border-site-accent bg-[rgba(var(--accent-rgb),0.12)] text-site-heading',
						]}
						href={getPageUrl(page)}
						aria-current={page === currentPage ? 'page' : undefined}
					>
						{page}
					</a>
				))}
			</div>
			<a
				class:list={[
					'inline-flex min-h-9 min-w-9 items-center justify-center rounded-md border border-site-border px-[0.65rem] py-[0.35rem] text-[0.9rem] text-site-text no-underline transition-colors duration-200 hover:border-[rgba(var(--accent-rgb),0.45)] hover:bg-[rgba(var(--accent-rgb),0.08)] hover:text-site-heading max-[720px]:w-full',
					currentPage === totalPages && 'pointer-events-none opacity-45',
				]}
				href={currentPage === totalPages ? undefined : getPageUrl(currentPage + 1)}
				aria-disabled={currentPage === totalPages ? 'true' : undefined}
			>
				Next
			</a>
		</nav>
	)
}
