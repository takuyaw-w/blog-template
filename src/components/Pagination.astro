---
import { getPageNumbers } from '../utils/blog';

interface Props {
	currentPage: number;
	totalPages: number;
	basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;
const normalizeBasePath = (path: string) => (path === '/' ? '' : path.replace(/\/$/, ''));
const base = normalizeBasePath(basePath);
const getPageUrl = (page: number) => (page === 1 ? (base ? `${base}/` : '/') : `${base}/page/${page}/`);
const pages = getPageNumbers(totalPages);
---

{
	totalPages > 1 && (
		<nav class="pagination" aria-label="Pagination">
			<a
				class:list={['pagination-link', { disabled: currentPage === 1 }]}
				href={currentPage === 1 ? undefined : getPageUrl(currentPage - 1)}
				aria-disabled={currentPage === 1 ? 'true' : undefined}
			>
				Prev
			</a>
			<div class="pagination-pages">
				{pages.map((page) => (
					<a
						class:list={['pagination-link', 'page-number', { current: page === currentPage }]}
						href={getPageUrl(page)}
						aria-current={page === currentPage ? 'page' : undefined}
					>
						{page}
					</a>
				))}
			</div>
			<a
				class:list={['pagination-link', { disabled: currentPage === totalPages }]}
				href={currentPage === totalPages ? undefined : getPageUrl(currentPage + 1)}
				aria-disabled={currentPage === totalPages ? 'true' : undefined}
			>
				Next
			</a>
		</nav>
	)
}
<style>
	.pagination {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 2rem;
	}
	.pagination-pages {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.4rem;
	}
	.pagination-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.25rem;
		min-height: 2.25rem;
		padding: 0.35rem 0.65rem;
		border: 1px solid rgb(var(--border));
		border-radius: 6px;
		color: rgb(var(--gray-dark));
		font-size: 0.9rem;
		text-decoration: none;
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease;
	}
	.pagination-link:hover {
		border-color: rgba(var(--accent-rgb), 0.45);
		background-color: rgba(var(--accent-rgb), 0.08);
		color: rgb(var(--black));
	}
	.pagination-link.current {
		border-color: var(--accent);
		background-color: rgba(var(--accent-rgb), 0.12);
		color: rgb(var(--black));
	}
	.pagination-link.disabled {
		pointer-events: none;
		opacity: 0.45;
	}
	@media (max-width: 720px) {
		.pagination {
			display: block;
		}
		.pagination-pages {
			margin: 0.75rem 0;
		}
		.pagination > .pagination-link {
			width: 100%;
		}
	}
</style>
