---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import {
	getBlogTaxonomyBasePath,
	getBlogTaxonomyCopy,
	getBlogTaxonomyIndexPath,
	getBlogTaxonomyPage,
	type BlogTaxonomyType,
} from '../utils/blog';
import { getProjectsByYear } from '../utils/projects';
import BackLink from './BackLink.astro';
import Pagination from './Pagination.astro';
import PostList from './PostList.astro';
import ProjectList from './ProjectList.astro';

interface Props {
	type: BlogTaxonomyType;
	value: string;
	currentPage?: number;
}

const { type, value, currentPage = 1 } = Astro.props;
const { currentPosts, totalPages } = await getBlogTaxonomyPage(type, value, currentPage);
const projects = type === 'year' && currentPage === 1 ? await getProjectsByYear(value) : [];
const copy = getBlogTaxonomyCopy(type, value);
const pageTitle =
	currentPage === 1 ? `${value} | ${SITE_TITLE}` : `${value} | Page ${currentPage} | ${SITE_TITLE}`;
---

<PageLayout title={pageTitle} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<BackLink href={getBlogTaxonomyIndexPath(type)} />
		<h1 class="taxonomy-title">{value}</h1>
		{
			type === 'year' ? (
				<>
					<section class="taxonomy-section" aria-labelledby="year-blog-heading">
						<h2 id="year-blog-heading">Blog</h2>
						<PostList
							posts={currentPosts}
							emptyTitle={copy.emptyTitle}
							emptyDescription={copy.emptyDescription}
						/>
					</section>
					{currentPage === 1 && (
						<section class="taxonomy-section year-projects" aria-labelledby="year-projects-heading">
							<h2 id="year-projects-heading">Projects</h2>
							<ProjectList
								projects={projects}
								emptyTitle={`No projects from ${value} yet.`}
								emptyDescription="Published projects from this year will appear here."
							/>
						</section>
					)}
				</>
			) : (
				<PostList posts={currentPosts} emptyTitle={copy.emptyTitle} emptyDescription={copy.emptyDescription} />
			)
		}
		<Pagination currentPage={currentPage} totalPages={totalPages} basePath={getBlogTaxonomyBasePath(type, value)} />
	</main>
</PageLayout>
<style>
	.taxonomy-section + .taxonomy-section {
		margin-top: 3rem;
	}
	.taxonomy-section h2 {
		margin-bottom: 0.75rem;
		font-size: 1.25rem;
	}
	.year-projects :global(.project-list) {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		columns: unset;
	}
	.year-projects :global(.project) {
		display: flex;
		margin: 0;
	}
	@media (max-width: 1080px) {
		.year-projects :global(.project-list) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 720px) {
		.year-projects :global(.project-list) {
			grid-template-columns: 1fr;
		}
	}
</style>
