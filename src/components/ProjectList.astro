---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { toTaxonomySlug } from '../utils/blog';
import EmptyState from './EmptyState.astro';
import ProjectActionLink from './ProjectActionLink.astro';

type ProjectEntry = CollectionEntry<'projects'>;

type Props = {
	projects: ProjectEntry[];
	emptyTitle?: string;
	emptyDescription?: string;
};

const {
	projects,
	emptyTitle = 'No projects yet.',
	emptyDescription = 'Published projects will appear here.',
} = Astro.props;
const getProjectPath = (id: string) => `/projects/${id}/`;
const getProjectTagPath = (tag: string) => `/projects/tags/${toTaxonomySlug(tag)}/`;
---

{
	projects.length > 0 ? (
		<ul class="project-list">
			{projects.map((project) => (
				<li class="project">
					<a class="project-link" href={getProjectPath(project.id)}>
						{project.data.heroImage && (
							<Image
								class="project-image"
								src={project.data.heroImage}
								alt={project.data.heroImageAlt ?? `${project.data.title} preview`}
								width={640}
								height={360}
							/>
						)}
						<span class="project-card-body">
							<span class="meta">
								{project.data.category} / {project.data.status} / {project.data.period}
							</span>
							<span class="project-header">
								<span class="project-title">{project.data.title}</span>
								<span class="link-indicator" aria-hidden="true" />
							</span>
							<span class="description">{project.data.description}</span>
						</span>
					</a>
					{project.data.tags.length > 0 && (
						<ul class="tags" aria-label={`${project.data.title} tags`}>
							{project.data.tags.map((tag) => (
								<li>
									<a href={getProjectTagPath(tag)}>{tag}</a>
								</li>
							))}
						</ul>
					)}
					{(project.data.url || project.data.repository) && (
						<div class="links">
							{project.data.url && <ProjectActionLink href={project.data.url} label="View project" />}
							{project.data.repository && <ProjectActionLink href={project.data.repository} label="Repository" />}
						</div>
					)}
				</li>
			))}
		</ul>
	) : (
		<EmptyState title={emptyTitle} description={emptyDescription} ariaLabel="No projects" />
	)
}

<style>
	.project-list {
		columns: 3 18rem;
		column-gap: 1rem;
		margin: 0;
		padding: 0;
		list-style-type: none;
	}
	.project {
		display: inline-flex;
		flex-direction: column;
		break-inside: avoid;
		width: 100%;
		min-width: 0;
		margin: 0 0 1rem;
		padding: 0;
		border: 1px solid rgba(var(--border), 0.86);
		border-radius: 8px;
		background: rgba(var(--surface-strong), 0.62);
	}
	.project-link {
		display: flex;
		flex-direction: column;
		min-width: 0;
		text-decoration: none;
	}
	.project-link:focus-visible {
		outline: 2px solid rgba(var(--accent-rgb), 0.45);
		outline-offset: 3px;
	}
	.project-image {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		border-radius: 7px 7px 0 0;
		object-fit: cover;
	}
	.project-card-body {
		display: flex;
		flex-direction: column;
		min-width: 0;
		padding: 1rem;
	}
	.project-header {
		display: flex;
		gap: 0.75rem;
		align-items: flex-start;
		justify-content: space-between;
		margin-top: 0.35rem;
	}
	.project-title {
		margin: 0;
		color: rgb(var(--black));
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1.3;
	}
	.meta {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.78rem;
		line-height: 1.4;
	}
	.link-indicator {
		flex: 0 0 auto;
		width: 0.45rem;
		height: 0.45rem;
		margin-top: 0.35rem;
		border-top: 2px solid rgba(var(--gray), 0.78);
		border-right: 2px solid rgba(var(--gray), 0.78);
		transform: rotate(45deg);
	}
	.description {
		display: block;
		margin: 0.55rem 0 0;
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
		line-height: 1.55;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0 1rem 1rem;
		list-style-type: none;
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		padding: 0 1rem 1rem;
	}
	.tags + .links {
		padding-top: 0;
	}
	.tags a {
		display: inline-flex;
		padding: 0.1rem 0.5rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		line-height: 1.6;
		text-decoration: none;
	}
	.tags a:focus-visible {
		outline: 2px solid rgba(var(--accent-rgb), 0.45);
		outline-offset: 3px;
	}
	@media (max-width: 1080px) {
		.project-list {
			columns: 2 18rem;
		}
	}
	@media (max-width: 720px) {
		.project-list {
			columns: 1;
		}
	}
</style>
