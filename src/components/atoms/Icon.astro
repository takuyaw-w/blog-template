---
import type { HTMLAttributes } from 'astro/types';
import BrandGithub from '@tabler/icons/outline/brand-github.svg?raw';
import BrandX from '@tabler/icons/outline/brand-x.svg?raw';
import ExternalLink from '@tabler/icons/outline/external-link.svg?raw';
import Moon from '@tabler/icons/outline/moon.svg?raw';
import Rss from '@tabler/icons/outline/rss.svg?raw';
import Sun from '@tabler/icons/outline/sun.svg?raw';

const icons = {
	'brand-github': BrandGithub,
	'brand-x': BrandX,
	'external-link': ExternalLink,
	moon: Moon,
	rss: Rss,
	sun: Sun,
} as const;

interface Props extends HTMLAttributes<'span'> {
	name: keyof typeof icons;
	size?: number | string;
}

const { name, size = 24, class: className, style, ...attrs } = Astro.props;
const iconSize = typeof size === 'number' ? `${size}px` : size;
const iconStyle = [`--icon-size: ${iconSize}`, style].filter(Boolean).join('; ');
---

<span
	{...attrs}
	aria-hidden="true"
	class:list={['inline-flex size-(--icon-size) flex-none leading-none [&_svg]:block [&_svg]:size-full', className]}
	style={iconStyle}
	set:html={icons[name]}
/>
