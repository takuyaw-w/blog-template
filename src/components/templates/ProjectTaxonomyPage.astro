---
import ProjectList from '../organisms/ProjectList.astro';
import BackLink from '../molecules/BackLink.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import {
	getProjectTaxonomyCopy,
	getProjectTaxonomyIndexPath,
	getProjectTaxonomyPage,
	type ProjectTaxonomyType,
} from '../../utils/projects';

interface Props {
	type: ProjectTaxonomyType;
	value: string;
}

const { type, value } = Astro.props;
const projects = await getProjectTaxonomyPage(type, value);
const copy = getProjectTaxonomyCopy(type, value, projects.length);
---

<PageLayout title={`${value} Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="wide-main">
		<BackLink href={getProjectTaxonomyIndexPath(type)} />
		<section class="mb-8">
			<p class="mt-0 mb-[0.35rem] text-[0.85rem] font-bold tracking-normal text-site-muted uppercase">{copy.eyebrow}</p>
			<h1 class="mt-0 mb-2 text-4xl">{value}</h1>
			<p class="m-0 max-w-160 text-site-muted">{copy.lead}</p>
		</section>
		<ProjectList projects={projects} emptyTitle={copy.emptyTitle} emptyDescription={copy.emptyDescription} />
	</main>
</PageLayout>
