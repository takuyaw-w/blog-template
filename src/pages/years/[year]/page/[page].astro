---
import BlogTaxonomyPage from '../../../../components/BlogTaxonomyPage.astro';
import { getYearStaticPaths } from '../../../../utils/yearly';

export async function getStaticPaths() {
	return getYearStaticPaths(true);
}

const value = Astro.props.value ?? Astro.params.year ?? '';
const currentPage = Number(Astro.props.page);
---

<BlogTaxonomyPage type="year" value={value} currentPage={currentPage} />
