---
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { getYearActivitySummaries } from '../../utils/yearly';

const years = await getYearActivitySummaries();
---

<PageLayout title={`Years | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main year-index-page">
		<header class="year-index-header">
			<p class="eyebrow">Archive</p>
			<h1>Years</h1>
			<p class="lead">Blog and project activity, grouped by year.</p>
		</header>
		<section class="year-index" aria-label="Years">
			{
				years.length > 0 ? (
					<ul class="year-list">
						{years.map((year) => (
							<li>
								<a href={`/years/${year.year}/`}>
									<span class="year-label">{year.year}</span>
									<span class="year-metrics" aria-label={`${year.year} activity counts`}>
										<span>
											<strong>{year.blogCount}</strong>
											Blog
										</span>
										<span>
											<strong>{year.projectCount}</strong>
											Projects
										</span>
										<span>
											<strong>{year.totalCount}</strong>
											Total
										</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty-copy">Years will appear here once blog entries or projects are published.</p>
				)
			}
		</section>
	</main>
</PageLayout>

<style>
	.year-index-page {
		width: 920px;
	}
	.year-index-header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgb(var(--border));
	}
	.eyebrow {
		margin: 0 0 0.35rem;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	.year-index-header h1 {
		margin: 0;
		font-size: clamp(2.15rem, 9vw, 3.052rem);
	}
	.lead {
		max-width: 680px;
		margin: 0.75rem 0 0;
		color: rgb(var(--gray-dark));
		font-size: 1rem;
		line-height: 1.65;
	}
	.year-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.year-list li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.year-list a {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		padding: 1rem 0.75rem;
		border-radius: 6px;
		color: rgb(var(--black));
		text-decoration: none;
		transition: background-color 0.2s ease;
	}
	.year-list a:hover,
	.year-list a:focus-visible {
		background-color: rgba(var(--gray-light), 45%);
	}
	.year-label {
		font-weight: 700;
		line-height: 1.35;
	}
	.year-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(4.6rem, 1fr));
		gap: 0.5rem;
		min-width: 0;
	}
	.year-metrics > span {
		display: block;
		padding: 0.55rem 0.65rem;
		border: 1px solid rgba(var(--border), 0.9);
		border-radius: 6px;
		background: rgba(var(--surface-strong), 0.42);
		color: rgb(var(--gray));
		font-size: 0.85rem;
		line-height: 1.35;
		text-align: right;
	}
	.year-metrics strong {
		display: block;
		color: rgb(var(--black));
		font-size: 1rem;
		line-height: 1.15;
	}
	.empty-copy {
		margin: 0;
		padding: 1rem 0.75rem;
		border-top: 1px solid rgb(var(--gray-light));
		border-bottom: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.year-list a {
			grid-template-columns: 1fr;
		}
		.year-metrics {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
		.year-metrics > span {
			text-align: left;
		}
	}
</style>
