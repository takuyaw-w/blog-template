---
import TaxonomyList from '../../components/TaxonomyList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { countValues, getBlogPosts, getPostYear } from '../../utils/blog';
import { getBlogMonths } from '../../utils/monthly';

const posts = await getBlogPosts();
const years = countValues(posts.map((post) => getPostYear(post.data.pubDate))).sort(
	([a], [b]) => Number(b) - Number(a),
);
const months = await getBlogMonths();
---

<PageLayout title={`Years | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<h1 class="taxonomy-title">Years</h1>
		<TaxonomyList
			items={years}
			basePath="/years"
			emptyTitle="No years yet."
			emptyDescription="Years will appear here once blog entries are published."
		/>
		{
			months.length > 0 && (
				<section class="month-index" aria-labelledby="month-index-title">
					<h2 id="month-index-title">Monthly Logs</h2>
					<ul>
						{months.map((month) => (
							<li>
								<a href={month.path}>
									<span>{month.label}</span>
									<span>
										{month.posts.length} blog / {month.projects.length} projects
									</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)
		}
	</main>
</PageLayout>

<style>
	.month-index {
		margin-top: 3rem;
	}
	.month-index h2 {
		margin-bottom: 0.75rem;
		font-size: 1.25rem;
	}
	.month-index ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.month-index li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.month-index a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0.75rem;
		border-radius: 6px;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.month-index a:hover,
	.month-index a:focus-visible {
		background-color: rgba(var(--gray-light), 45%);
	}
	.month-index a span:last-child {
		color: rgb(var(--gray));
		font-size: 0.85rem;
		white-space: nowrap;
	}
	@media (max-width: 720px) {
		.month-index a {
			display: block;
		}
		.month-index a span:last-child {
			display: block;
			margin-top: 0.15rem;
			white-space: normal;
		}
	}
</style>
