---
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { getYearActivitySummaries } from '../../utils/yearly';

const years = await getYearActivitySummaries();
---

<PageLayout title={`Years | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="w-[920px]">
		<header class="mb-10 border-b border-site-border pb-6">
			<p class="mt-0 mb-[0.35rem] text-[0.85rem] font-bold tracking-normal text-site-muted uppercase">Archive</p>
			<h1 class="m-0 text-[clamp(2.15rem,9vw,3.052rem)]">Years</h1>
			<p class="mt-3 mb-0 max-w-[680px] text-base leading-[1.65] text-site-text">Blog and project activity, grouped by year.</p>
		</header>
		<section aria-label="Years">
			{
				years.length > 0 ? (
					<ul class="m-0 list-none p-0">
						{years.map((year) => (
							<li class="border-b border-site-rule">
								<a
									class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-4 rounded-md px-3 py-4 text-site-heading no-underline transition-colors duration-200 hover:bg-[rgba(var(--gray-light),0.45)] focus-visible:bg-[rgba(var(--gray-light),0.45)] max-[720px]:grid-cols-1"
									href={`/years/${year.year}/`}
								>
									<span class="font-bold leading-[1.35]">{year.year}</span>
									<span
										class="grid min-w-0 grid-cols-3 gap-2 [grid-template-columns:repeat(3,minmax(4.6rem,1fr))] max-[720px]:grid-cols-3 max-[720px]:[grid-template-columns:repeat(3,minmax(0,1fr))]"
										aria-label={`${year.year} activity counts`}
									>
										<span class="block rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.42)] px-[0.65rem] py-[0.55rem] text-right text-[0.85rem] leading-[1.35] text-site-muted max-[720px]:text-left">
											<strong class="block text-base leading-[1.15] text-site-heading">{year.blogCount}</strong>
											Blog
										</span>
										<span class="block rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.42)] px-[0.65rem] py-[0.55rem] text-right text-[0.85rem] leading-[1.35] text-site-muted max-[720px]:text-left">
											<strong class="block text-base leading-[1.15] text-site-heading">{year.projectCount}</strong>
											Projects
										</span>
										<span class="block rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.42)] px-[0.65rem] py-[0.55rem] text-right text-[0.85rem] leading-[1.35] text-site-muted max-[720px]:text-left">
											<strong class="block text-base leading-[1.15] text-site-heading">{year.totalCount}</strong>
											Total
										</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="m-0 border-y border-site-rule px-3 py-4 text-site-muted">Years will appear here once blog entries or projects are published.</p>
				)
			}
		</section>
	</main>
</PageLayout>
