---
import BlogTaxonomyPage from '../../components/BlogTaxonomyPage.astro';
import { getBlogTaxonomyStaticPaths } from '../../utils/blog';

export async function getStaticPaths() {
	return getBlogTaxonomyStaticPaths('year');
}

const value = Astro.props.value ?? Astro.params.year ?? '';
---

<BlogTaxonomyPage type="year" value={value} />
