---
import Pagination from '../../components/Pagination.astro';
import PostList from '../../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import {
	fromTaxonomySlug,
	getBlogPosts,
	getPageItems,
	getTotalPages,
	sortPostsByDate,
	toTaxonomySlug,
} from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getBlogPosts();
	const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

	return tags.map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const tagName = tag ?? fromTaxonomySlug(Astro.params.tag ?? '');
const posts = sortPostsByDate((await getBlogPosts()).filter((post) => post.data.tags.includes(tagName)));
const currentPage = 1;
const totalPages = getTotalPages(posts.length);
const currentPosts = getPageItems(posts, currentPage);
---

<PageLayout title={`${tagName} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<a class="back-link" href="/tags/" data-history-back>Back</a>
		<h1 class="taxonomy-title">{tagName}</h1>
		<PostList
			posts={currentPosts}
			emptyTitle={`No blog posts tagged ${tagName} yet.`}
			emptyDescription="Published blog entries with this tag will appear here."
		/>
		<Pagination currentPage={currentPage} totalPages={totalPages} basePath={`/tags/${toTaxonomySlug(tagName)}`} />
	</main>
	<style>
		.back-link {
			display: inline-flex;
			margin-bottom: 1.5rem;
			color: rgb(var(--gray));
			font-size: 0.95rem;
			text-decoration: none;
		}
		.back-link:focus-visible {
			outline: 2px solid rgba(var(--accent-rgb), 0.45);
			outline-offset: 3px;
		}
	</style>
	<script>
		import { bindHistoryBackLinks } from '../../utils/history-back';

		bindHistoryBackLinks();
	</script>
</PageLayout>
