---
import BlogTaxonomyPage from '../../../../components/BlogTaxonomyPage.astro';
import { fromTaxonomySlug, getBlogTaxonomyStaticPaths } from '../../../../utils/blog';

export async function getStaticPaths() {
	return getBlogTaxonomyStaticPaths('tag', true);
}

const value = Astro.props.value ?? fromTaxonomySlug(Astro.params.tag ?? '');
const currentPage = Number(Astro.props.page);
---

<BlogTaxonomyPage type="tag" value={value} currentPage={currentPage} />
