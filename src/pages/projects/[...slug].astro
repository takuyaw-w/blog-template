---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectActionLink from '../../components/ProjectActionLink.astro';
import { SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { toTaxonomySlug } from '../../utils/blog';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
const { heroImage, heroImageAlt, gallery } = project.data;
const hasHeroImage = Boolean(heroImage);
const getProjectTagPath = (tag: string) => `/projects/tags/${toTaxonomySlug(tag)}/`;
const getProjectCategoryPath = (category: string) => `/projects/categories/${toTaxonomySlug(category)}/`;
---

<PageLayout title={`${project.data.title} | Projects | ${SITE_TITLE}`} description={project.data.description}>
	<main class="project-detail-main">
		<a class="back-link" href="/projects/" data-history-back>Back</a>
		<article class="project-detail">
			<header class:list={['project-header', { 'project-header--without-hero': !hasHeroImage }]}>
				<h1 class="project-title">{project.data.title}</h1>
				<p class="description">{project.data.description}</p>
				<ul class="meta">
					<li class="category-item">
						<a href={getProjectCategoryPath(project.data.category)}>{project.data.category}</a>
					</li>
					<li>{project.data.status}</li>
					<li>{project.data.period}</li>
					{
						project.data.tags.map((tag) => (
							<li class="tag-item">
								<a href={getProjectTagPath(tag)}>{tag}</a>
							</li>
						))
					}
				</ul>
				{
					(project.data.url || project.data.repository) && (
						<div class="actions">
							{project.data.url && <ProjectActionLink href={project.data.url} label="View project" />}
							{project.data.repository && <ProjectActionLink href={project.data.repository} label="Repository" />}
						</div>
					)
				}
			</header>
			{
				heroImage && (
					<Image
						class="project-hero-image"
						src={heroImage}
						alt={heroImageAlt ?? `${project.data.title} preview`}
						width={1200}
						height={630}
					/>
				)
			}
			<div class="project-content prose prose-lg prose-blog">
				<Content />
			</div>
			{
				gallery.length > 0 && (
					<section class="project-gallery" aria-labelledby="project-gallery-heading">
						<h2 id="project-gallery-heading">Gallery</h2>
						<div class="gallery-grid">
							{gallery.map((item) => (
								<figure>
									<Image src={item.image} alt={item.alt} width={960} height={540} />
									{item.caption && <figcaption>{item.caption}</figcaption>}
								</figure>
							))}
						</div>
					</section>
				)
			}
		</article>
	</main>
<style>
	.project-detail-main {
		width: 1400px;
		max-width: calc(100% - 2em);
	}
	.back-link {
		display: inline-flex;
		margin-bottom: 2rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		text-decoration: none;
	}
	.back-link:focus-visible {
		outline: 2px solid rgba(var(--accent-rgb), 0.45);
		outline-offset: 3px;
	}
	.project-header {
		padding-bottom: 2rem;
		border-bottom: 1px solid rgb(var(--border));
	}
	.project-header--without-hero {
		padding-bottom: 0;
		border-bottom: 0;
	}
	.project-title {
		margin: 0;
		font-size: 2.6rem;
		line-height: 1.08;
	}
	.description {
		max-width: 820px;
		margin: 1rem 0 0;
		color: rgb(var(--gray-dark));
	}
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 1.25rem 0 0;
		padding: 0;
		list-style: none;
	}
	.meta li {
		padding: 0.2rem 0.65rem;
		border: 1px solid rgb(var(--border));
		border-radius: 999px;
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}
	.meta a {
		color: inherit;
		text-decoration: none;
	}
	.meta .category-item:focus-within,
	.meta .tag-item:focus-within {
		outline: 2px solid rgba(var(--accent-rgb), 0.45);
		outline-offset: 3px;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 1.5rem;
	}
	.project-hero-image {
		display: block;
		width: 100%;
		max-width: 1200px;
		aspect-ratio: 1200 / 630;
		margin: 2rem auto 0;
		border: 1px solid rgba(var(--border), 0.8);
		border-radius: 12px;
		object-fit: cover;
	}
	.project-content {
		margin-top: 2.5rem;
		color: rgb(var(--gray-dark));
	}
	.project-content :global(h2) {
		margin-top: 2.25rem;
		font-size: 1.5rem;
	}
	.project-content :global(h3) {
		margin-top: 1.75rem;
		font-size: 1.2rem;
	}
	.project-content :global(p),
	.project-content :global(ul),
	.project-content :global(ol) {
		max-width: 1040px;
	}
	.project-gallery {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid rgb(var(--border));
	}
	.project-gallery h2 {
		margin: 0 0 1rem;
		font-size: 1.35rem;
	}
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.gallery-grid figure {
		margin: 0;
	}
	.gallery-grid img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid rgba(var(--border), 0.8);
		border-radius: 10px;
		object-fit: cover;
	}
	.gallery-grid figcaption {
		margin-top: 0.45rem;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		line-height: 1.5;
	}
	@media (max-width: 980px) {
		.project-detail-main {
			width: 1040px;
		}
	}
	@media (max-width: 720px) {
		.project-title {
			font-size: 2rem;
		}
		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
<script>
	import { bindHistoryBackLinks } from '../../utils/history-back';

	bindHistoryBackLinks();
</script>
</PageLayout>
