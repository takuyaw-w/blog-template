---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectActionLink from '../../components/molecules/ProjectActionLink.astro';
import { SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { getProjectCategoryPath, getProjectTagPath } from '../../utils/projects';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
const { heroImage, heroImageAlt, gallery } = project.data;
const hasHeroImage = Boolean(heroImage);
const ogImage = new URL(`/og/projects/${project.id}.png`, Astro.site ?? Astro.url);
---

<PageLayout title={`${project.data.title} | Projects | ${SITE_TITLE}`} description={project.data.description} image={ogImage}>
	<main class="w-[calc(var(--spacing-site-wide)+2em)] max-w-full max-[980px]:w-[calc(var(--spacing-site-content)+2em)]">
		<article class="project-detail">
			<header class:list={[hasHeroImage && 'border-b border-site-border pb-8']}>
				<h1 class="m-0 text-[2.6rem] leading-[1.08] max-[720px]:text-4xl">{project.data.title}</h1>
				<p class="mt-4 mb-0 max-w-[820px] text-site-text">{project.data.description}</p>
				<ul class="mt-5 flex list-none flex-wrap gap-3 p-0">
					<li
						class="rounded-full border border-site-border px-[0.65rem] py-[0.2rem] text-[0.85rem] text-site-muted focus-within:outline-2 focus-within:outline-offset-[3px] focus-within:outline-[rgba(var(--accent-rgb),0.45)]"
					>
						<a class="text-inherit no-underline" href={getProjectCategoryPath(project.data.category)}>
							{project.data.category}
						</a>
					</li>
					<li class="rounded-full border border-site-border px-[0.65rem] py-[0.2rem] text-[0.85rem] text-site-muted">
						{project.data.status}
					</li>
					<li class="rounded-full border border-site-border px-[0.65rem] py-[0.2rem] text-[0.85rem] text-site-muted">
						{project.data.period}
					</li>
					{
						project.data.tags.map((tag) => (
							<li class="rounded-full border border-site-border px-[0.65rem] py-[0.2rem] text-[0.85rem] text-site-muted focus-within:outline-2 focus-within:outline-offset-[3px] focus-within:outline-[rgba(var(--accent-rgb),0.45)]">
								<a class="text-inherit no-underline" href={getProjectTagPath(tag)}>
									{tag}
								</a>
							</li>
						))
					}
				</ul>
				{
					(project.data.url || project.data.repository) && (
						<div class="mt-6 flex flex-wrap gap-[0.9rem]">
							{project.data.url && <ProjectActionLink href={project.data.url} label="View project" />}
							{project.data.repository && <ProjectActionLink href={project.data.repository} label="Repository" />}
						</div>
					)
				}
			</header>
			{
				heroImage && (
					<Image
						class="mx-auto mt-8 block aspect-[1200/630] w-full max-w-[1200px] rounded-xl border border-site-border-soft object-cover"
						src={heroImage}
						alt={heroImageAlt ?? `${project.data.title} preview`}
						width={1200}
						height={630}
						loading="eager"
						decoding="sync"
						fetchpriority="high"
					/>
				)
			}
			<div
				class="prose prose-lg prose-blog mt-10 text-site-text [&_h2]:mt-9 [&_h2]:text-2xl [&_h3]:mt-7 [&_h3]:text-[1.2rem] [&_ol]:max-w-[var(--spacing-site-content)] [&_p]:max-w-[var(--spacing-site-content)] [&_ul]:max-w-[var(--spacing-site-content)]"
			>
				<Content />
			</div>
			{
				gallery.length > 0 && (
					<section class="mt-12 border-t border-site-border pt-8" aria-labelledby="project-gallery-heading">
						<h2 class="mt-0 mb-4 text-[1.35rem]" id="project-gallery-heading">
							Gallery
						</h2>
						<div class="grid grid-cols-2 gap-4 max-[720px]:grid-cols-1">
							{gallery.map((item) => (
								<figure class="m-0">
									<Image
										class="block h-auto w-full rounded-[10px] border border-site-border-soft object-cover"
										src={item.image}
										alt={item.alt}
										width={960}
										height={540}
										loading="lazy"
										decoding="async"
									/>
									{item.caption && <figcaption class="mt-[0.45rem] text-[0.85rem] leading-[1.5] text-site-muted">{item.caption}</figcaption>}
								</figure>
							))}
						</div>
					</section>
				)
			}
		</article>
	</main>
</PageLayout>
