---
import ProjectList from '../../components/organisms/ProjectList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { getProjects } from '../../utils/projects';

const projects = await getProjects();
---

<PageLayout title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="w-[calc(var(--spacing-site-wide)+2em)]">
		<section class="mb-8">
			<h1 class="mb-2 text-4xl">Projects</h1>
			<p class="m-0 max-w-160 text-site-muted">A short index of projects, experiments, and ongoing work.</p>
		</section>
		<ProjectList
			projects={projects}
			emptyTitle="No projects yet."
			emptyDescription="Published projects will appear here."
		/>
	</main>
</PageLayout>
