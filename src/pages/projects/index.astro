---
import ProjectList from '../../components/ProjectList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { getProjects } from '../../utils/projects';

const projects = await getProjects();
---

<PageLayout title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="projects-main">
		<section class="page-header">
			<h1>Projects</h1>
			<p class="lead">A short index of projects, experiments, and ongoing work.</p>
		</section>
		<ProjectList
			projects={projects}
			emptyTitle="No projects yet."
			emptyDescription="Published projects will appear here."
		/>
	</main>
</PageLayout>
<style>
	.projects-main {
		width: calc(1400px + 2em);
	}
	.page-header {
		margin-bottom: 2rem;
	}
	h1 {
		margin-bottom: 0.5rem;
		font-size: 2rem;
	}
	.lead {
		max-width: 640px;
		margin: 0;
		color: rgb(var(--gray));
	}
</style>
