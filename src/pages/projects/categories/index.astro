---
import TaxonomyList from '../../../components/TaxonomyList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import PageLayout from '../../../layouts/PageLayout.astro';
import { getProjects, getProjectTaxonomyValues } from '../../../utils/projects';

const categories = getProjectTaxonomyValues(await getProjects(), 'category');
---

<PageLayout title={`Project Categories | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<h1 class="taxonomy-title">Project Categories</h1>
		<TaxonomyList
			items={categories}
			basePath="/projects/categories"
			emptyTitle="No project categories yet."
			emptyDescription="Project categories will appear here once projects are published."
		/>
	</main>
</PageLayout>
