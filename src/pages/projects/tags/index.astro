---
import TaxonomyList from '../../../components/molecules/TaxonomyList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import PageLayout from '../../../layouts/PageLayout.astro';
import { getProjects, getProjectTaxonomyValues } from '../../../utils/projects';

const tags = getProjectTaxonomyValues(await getProjects(), 'tag');
---

<PageLayout title={`Project Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<h1 class="taxonomy-title">Project Tags</h1>
		<TaxonomyList
			items={tags}
			basePath="/projects/tags"
			emptyTitle="No project tags yet."
			emptyDescription="Project tags will appear here once projects are published."
		/>
	</main>
</PageLayout>
