---
import ProjectTaxonomyPage from '../../../components/templates/ProjectTaxonomyPage.astro';
import { fromTaxonomySlug } from '../../../utils/blog';
import { getProjectTaxonomyStaticPaths } from '../../../utils/projects';

export async function getStaticPaths() {
	return getProjectTaxonomyStaticPaths('tag');
}

const value = Astro.props.value ?? fromTaxonomySlug(Astro.params.tag ?? '');
---

<ProjectTaxonomyPage type="tag" value={value} />
