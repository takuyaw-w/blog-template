---
import { SITE_TITLE } from '../consts';
import PageLayout from '../layouts/PageLayout.astro';

const pageTitle = `404 | ${SITE_TITLE}`;
const pageDescription = '指定されたページは見つかりませんでした。';
---

<PageLayout title={pageTitle} description={pageDescription}>
	<main class="not-found-main">
		<section class="not-found" aria-labelledby="not-found-title">
			<div class="not-found-copy">
				<p class="eyebrow">HTTP 404 / missing log entry</p>
				<h1 id="not-found-title">このログは見つかりませんでした</h1>
				<p class="lead">
					URLが変わったか、まだ書かれていないページのようです。Blogの一覧かProjectsから、近いエントリを探せます。
				</p>
				<nav class="not-found-links" aria-label="404 navigation">
					<a href="/">Blogへ戻る</a>
					<a href="/projects/">Projectsを見る</a>
				</nav>
			</div>
			<aside class="log-panel" aria-label="Request trace">
				<div class="log-panel-header">
					<span></span>
					<span></span>
					<span></span>
				</div>
				<div class="log-lines">
					<p><span>06:37:12</span> GET requested path</p>
					<p><span>06:37:12</span> lookup content index</p>
					<p class="warning"><span>06:37:12</span> entry not found</p>
					<p><span>06:37:13</span> route fallback to /404.html</p>
					<p><span>06:37:13</span> suggest Blog / Projects</p>
				</div>
			</aside>
		</section>
	</main>
</PageLayout>

<style>
	.not-found-main {
		display: grid;
		width: 1100px;
		min-height: 60vh;
		align-items: center;
	}
	.not-found {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 26rem);
		gap: clamp(2rem, 6vw, 4rem);
		align-items: center;
	}
	.not-found-copy {
		max-width: 43rem;
	}
	.eyebrow {
		margin: 0 0 0.65rem;
		color: rgb(var(--gray));
		font-family: var(--font-mono);
		font-size: 0.95rem;
		letter-spacing: 0;
	}
	h1 {
		max-width: 9em;
		margin-bottom: 0.75rem;
		font-size: clamp(2.25rem, 8vw, 4.3rem);
		line-height: 1.08;
	}
	.lead {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.85;
	}
	.not-found-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1.15rem;
		margin-top: 1.8rem;
	}
	.not-found-links a {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration-color: rgba(var(--gray), 0.32);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}
	.not-found-links a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.log-panel {
		overflow: hidden;
		border: 1px solid rgb(var(--border));
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(var(--surface-strong), 0.98), rgba(var(--surface-soft), 0.72)),
			rgb(var(--surface-soft));
		box-shadow: 0 22px 55px rgba(var(--solarized-base03), 0.08);
	}
	.log-panel-header {
		display: flex;
		gap: 0.45rem;
		padding: 0.75rem 0.9rem;
		border-bottom: 1px solid rgba(var(--border), 0.78);
	}
	.log-panel-header span {
		width: 0.65rem;
		height: 0.65rem;
		border: 1px solid rgba(var(--gray), 0.24);
		border-radius: 999px;
		background: rgba(var(--surface), 0.88);
	}
	.log-lines {
		display: grid;
		gap: 0.8rem;
		padding: 1.1rem 1rem 1.2rem;
		font-family: var(--font-mono);
		font-size: 0.76rem;
		line-height: 1.5;
	}
	.log-lines p {
		display: grid;
		grid-template-columns: 4.7rem minmax(0, 1fr);
		gap: 0.75rem;
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	.log-lines span {
		color: rgb(var(--gray));
	}
	.log-lines .warning {
		color: rgb(var(--solarized-red));
	}
	@media (max-width: 820px) {
		.not-found-main {
			min-height: auto;
			padding-top: 2.5rem;
		}
		.not-found {
			grid-template-columns: 1fr;
		}
		.log-panel {
			order: -1;
		}
		h1 {
			max-width: 11em;
		}
	}
	@media (max-width: 520px) {
		.not-found-links {
			flex-direction: column;
			align-items: flex-start;
		}
		.log-lines {
			font-size: 0.68rem;
		}
		.log-lines p {
			grid-template-columns: 4.25rem minmax(0, 1fr);
			gap: 0.55rem;
		}
	}
</style>
