---
import { SITE_TITLE } from '../consts';
import PageLayout from '../layouts/PageLayout.astro';

const pageTitle = `404 | ${SITE_TITLE}`;
const pageDescription = '指定されたページは見つかりませんでした。';
---

<PageLayout title={pageTitle} description={pageDescription}>
	<main class="not-found-main">
		<section class="not-found" aria-labelledby="not-found-title">
			<p class="status-code">404</p>
			<h1 id="not-found-title">ページが見つかりませんでした</h1>
			<p class="lead">
				URLが変更されたか、ページが削除された可能性があります。BlogまたはProjectsから目的のページを探してください。
			</p>
			<nav class="not-found-links" aria-label="404 navigation">
				<a href="/">Blogへ戻る</a>
				<a href="/projects/">Projectsを見る</a>
			</nav>
		</section>
	</main>
</PageLayout>

<style>
	.not-found-main {
		display: grid;
		min-height: 54vh;
		align-items: center;
	}
	.not-found {
		max-width: 42rem;
	}
	.status-code {
		margin: 0 0 0.65rem;
		color: rgb(var(--gray));
		font-family: var(--font-mono);
		font-size: 0.95rem;
		letter-spacing: 0;
	}
	h1 {
		margin-bottom: 0.65rem;
		font-size: clamp(2rem, 8vw, 3.052rem);
	}
	.lead {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.8;
	}
	.not-found-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		margin-top: 2rem;
	}
	.not-found-links a {
		display: inline-flex;
		align-items: center;
		min-height: 2.5rem;
		color: var(--accent);
		font-weight: 700;
		text-decoration-color: rgba(var(--accent-rgb), 0.35);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}
	.not-found-links a:hover {
		text-decoration-color: var(--accent);
	}
</style>
