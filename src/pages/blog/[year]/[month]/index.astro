---
import PostList from '../../../../components/organisms/PostList.astro';
import ProjectList from '../../../../components/organisms/ProjectList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../../consts';
import PageLayout from '../../../../layouts/PageLayout.astro';
import {
	getBlogMonth,
	getBlogMonthPopularTags,
	getBlogMonthReadingTimeMinutes,
	getBlogMonths,
	getBlogMonthSummary,
} from '../../../../utils/monthly';

export async function getStaticPaths() {
	const months = await getBlogMonths();

	return months.map((month) => ({
		params: { year: month.year, month: month.month },
		props: { month },
	}));
}

const month =
	Astro.props.month ?? (await getBlogMonth(Astro.params.year ?? '', Astro.params.month ?? ''));

if (month === undefined) {
	return Astro.redirect('/blog/');
}

const totalReadingTime = getBlogMonthReadingTimeMinutes(month);
const popularTags = getBlogMonthPopularTags(month);
const monthlySummary = getBlogMonthSummary(month);
const pageTitle = `${month.label} | Monthly Log | ${SITE_TITLE}`;
---

<PageLayout title={pageTitle} description={SITE_DESCRIPTION}>
	<main class="w-[920px]">
		<a class="mb-6 inline-flex text-[0.9rem] text-site-muted no-underline hover:text-site-accent focus-visible:text-site-accent" href="/years/">Years</a>
		<header class="mb-10 border-b border-site-border pb-6">
			<p class="mt-0 mb-[0.35rem] text-[0.85rem] font-bold tracking-normal text-site-muted uppercase">Monthly Log</p>
			<h1 class="m-0 text-[clamp(2.15rem,9vw,3.052rem)]">{month.label}</h1>
			<p class="mt-3 mb-0 max-w-[680px] text-base leading-[1.65] text-site-text">{monthlySummary}</p>
			<div class="mt-6 grid grid-cols-3 gap-3 max-[720px]:grid-cols-1" aria-label={`${month.label} summary`}>
				<div class="rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.46)] p-[0.85rem]">
					<strong class="block text-[1.35rem] leading-[1.1] text-site-heading">{month.posts.length}</strong>
					<span class="mt-[0.2rem] block text-[0.78rem] leading-[1.3] text-site-muted">Blog</span>
				</div>
				<div class="rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.46)] p-[0.85rem]">
					<strong class="block text-[1.35rem] leading-[1.1] text-site-heading">{month.projects.length}</strong>
					<span class="mt-[0.2rem] block text-[0.78rem] leading-[1.3] text-site-muted">Projects</span>
				</div>
				<div class="rounded-md border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.46)] p-[0.85rem]">
					<strong class="block text-[1.35rem] leading-[1.1] text-site-heading">{totalReadingTime}</strong>
					<span class="mt-[0.2rem] block text-[0.78rem] leading-[1.3] text-site-muted">Min</span>
				</div>
			</div>
			{
				popularTags.length > 0 && (
					<ul class="mt-4 flex list-none flex-wrap gap-2 p-0" aria-label={`${month.label} frequent tags`}>
						{popularTags.map(([tag, count]) => (
							<li>
								<a
									class="inline-flex items-center gap-[0.35rem] rounded-full border border-[rgba(var(--border),0.9)] px-[0.55rem] py-[0.1rem] text-[0.82rem] leading-[1.7] text-site-muted no-underline hover:border-[rgba(var(--accent-rgb),0.32)] hover:text-site-text focus-visible:border-[rgba(var(--accent-rgb),0.32)] focus-visible:text-site-text"
									href={`/tags/${encodeURIComponent(tag)}/`}
								>
									{tag}
									<span class="text-[0.75rem] text-site-muted">{count}</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</header>

		<section aria-labelledby="monthly-blog">
			<h2 class="mb-3 text-xl" id="monthly-blog">Blog</h2>
			<PostList
				posts={month.posts}
				emptyTitle="No blog posts this month."
				emptyDescription="Published blog entries for this month will appear here."
			/>
		</section>

		<section class="mt-12" aria-labelledby="monthly-projects">
			<h2 class="mb-3 text-xl" id="monthly-projects">Projects</h2>
			<ProjectList
				projects={month.projects}
				emptyTitle="No project updates this month."
				emptyDescription="Projects with this month in their path or period will appear here."
			/>
		</section>
	</main>
</PageLayout>
