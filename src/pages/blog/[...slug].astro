---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getBlogPosts, getReadingTimeMinutes, getRelatedPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getBlogPosts();
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const posts = await getBlogPosts();
const { Content, headings } = await render(post);
const readingTimeMinutes = getReadingTimeMinutes(post.body);
const relatedPosts = getRelatedPosts(post, posts);
const slugCounts = new Map<string, number>();
const toHeadingSlug = (text: string) => {
	const baseSlug = text
		.toLowerCase()
		.trim()
		.replace(/[^\p{Letter}\p{Number}\s-]/gu, '')
		.replace(/\s+/g, '-');
	const count = slugCounts.get(baseSlug) ?? 0;

	slugCounts.set(baseSlug, count + 1);

	return count === 0 ? baseSlug : `${baseSlug}-${count}`;
};
const fallbackHeadings = post.body
	.split('\n')
	.map((line) => {
		const match = /^(#{2,3})\s+(.+)$/.exec(line);

		if (!match) {
			return undefined;
		}

		const text = match[2].replace(/[#\s]+$/g, '').trim();

		return {
			depth: match[1].length,
			slug: toHeadingSlug(text),
			text,
		};
	})
	.filter((heading) => heading !== undefined);
const tableOfContents = headings.length > 0 ? headings : fallbackHeadings;
---

<BlogPost
	{...post.data}
	postId={post.id}
	headings={tableOfContents}
	readingTimeMinutes={readingTimeMinutes}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
