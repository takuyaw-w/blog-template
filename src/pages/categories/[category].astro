---
import BlogTaxonomyPage from '../../components/BlogTaxonomyPage.astro';
import { fromTaxonomySlug, getBlogTaxonomyStaticPaths } from '../../utils/blog';

export async function getStaticPaths() {
	return getBlogTaxonomyStaticPaths('category');
}

const value = Astro.props.value ?? fromTaxonomySlug(Astro.params.category ?? '');
---

<BlogTaxonomyPage type="category" value={value} />
