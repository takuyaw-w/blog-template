---
import BlogTaxonomyPage from '../../../../components/templates/BlogTaxonomyPage.astro';
import { fromTaxonomySlug, getBlogTaxonomyStaticPaths } from '../../../../utils/blog';

export async function getStaticPaths() {
	return getBlogTaxonomyStaticPaths('category', true);
}

const value = Astro.props.value ?? fromTaxonomySlug(Astro.params.category ?? '');
const currentPage = Number(Astro.props.page);
---

<BlogTaxonomyPage type="category" value={value} currentPage={currentPage} />
