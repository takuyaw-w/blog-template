---
import TaxonomyList from '../../components/TaxonomyList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PageLayout from '../../layouts/PageLayout.astro';
import { countValues, getBlogPosts } from '../../utils/blog';

const posts = await getBlogPosts();
const categories = countValues(posts.map((post) => post.data.category));
---

<PageLayout title={`Categories | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<main class="listing-main">
		<h1 class="taxonomy-title">Categories</h1>
		<TaxonomyList
			items={categories}
			basePath="/categories"
			emptyTitle="No categories yet."
			emptyDescription="Categories will appear here once blog entries are published."
		/>
	</main>
</PageLayout>
