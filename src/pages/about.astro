---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import Icon from '../components/Icon.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { SOCIAL_ICON_NAMES } from '../utils/social-links';

const [about] = await getCollection('about');

if (!about) {
	throw new Error('Missing about content. Create src/content/about/index.md.');
}

const {
	title,
	description,
	name,
	role,
	age,
	location,
	company,
	experience,
	heroImage,
	highlights,
	skillGroups,
	career,
	uses,
	socials,
} = about.data;

---

<PageLayout title={`${title} | ${SITE_TITLE}`} description={description} image={heroImage}>
	<style>
			.about-main {
				width: 1400px;
				max-width: calc(100% - 2em);
			}
			.resume {
				padding: 2.5rem 0 1rem;
			}
			.profile-head {
				--profile-meta-width: clamp(25rem, calc((100vw - 2em - 3rem) * 0.382), 32rem);

				display: grid;
				grid-template-columns: minmax(0, 1fr) var(--profile-meta-width);
				gap: 3rem;
				align-items: end;
				padding-bottom: 2rem;
				border-bottom: 1px solid rgb(var(--border));
			}
			.identity {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}
			.name {
				margin: 0;
				font-size: 3rem;
				line-height: 1.05;
			}
			.role {
				margin: 0.75rem 0 0;
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}
			.summary {
				max-width: 42rem;
				margin: 1.5rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.profile-meta {
				display: grid;
				grid-template-columns: 4em minmax(0, 1fr);
				column-gap: 1.5rem;
				row-gap: 0.85rem;
				width: var(--profile-meta-width);
				max-width: 100%;
				margin: 0 0 0 auto;
				min-width: 0;
				justify-self: end;
			}
			.profile-photo {
				flex: 0 0 auto;
				display: block;
				width: 88px;
				height: 88px;
				border: 1px solid rgba(var(--border), 0.9);
				border-radius: 50%;
				object-fit: cover;
			}
			.meta-row {
				display: grid;
				grid-column: 1 / -1;
				grid-template-columns: subgrid;
				align-items: baseline;
				min-width: 0;
				padding-bottom: 0.65rem;
				border-bottom: 1px solid rgba(var(--border), 0.75);
			}
			.meta-row dt {
				color: rgb(var(--gray));
				font-size: 0.85rem;
				text-align: justify;
				text-align-last: justify;
				text-justify: inter-character;
			}
			.meta-row dd {
				margin: 0;
				color: rgb(var(--black));
				font-weight: 700;
				text-align: right;
				white-space: nowrap;
			}
			.resume-section {
				padding: 2.25rem 0;
				border-bottom: 1px solid rgb(var(--border));
			}
			.section-title {
				margin: 0 0 1.25rem;
				font-size: 1.35rem;
			}
			.highlights {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.9rem 1.5rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.highlights li {
				padding-left: 1rem;
				border-left: 3px solid var(--accent);
				color: rgb(var(--gray-dark));
			}
			.skill-groups {
				display: grid;
				gap: 0;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.skill-group {
				display: grid;
				grid-template-columns: 220px minmax(0, 1fr);
				gap: 2rem;
				min-width: 0;
				padding: 1.35rem 0;
				border-top: 1px solid rgba(var(--border), 0.8);
			}
			.skill-group:first-child {
				padding-top: 0;
				border-top: 0;
			}
			.skill-group:last-child {
				padding-bottom: 0;
			}
			.skill-group-head {
				min-width: 0;
			}
			.skill-category {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.35;
			}
			.skill-list {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.55rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.skill-list li {
				display: inline-flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.75rem;
				min-width: 0;
				padding: 0.55rem 0.7rem;
				border: 1px solid rgb(var(--border));
				border-radius: 8px;
				background: rgba(var(--surface-strong), 0.55);
				color: rgb(var(--gray-dark));
			}
			.skill-name {
				color: rgb(var(--black));
				font-weight: 700;
			}
			.skill-years {
				color: rgb(var(--gray));
				font-size: 0.78rem;
				white-space: nowrap;
			}
			.career-list {
				display: grid;
				gap: 1.5rem;
			}
			.career-item {
				display: grid;
				grid-template-columns: 140px minmax(0, 1fr);
				gap: 1.5rem;
			}
			.period {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.career-body h3 {
				margin: 0;
				font-size: 1.1rem;
			}
			.company {
				margin: 0.3rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.career-body p {
				margin: 0.75rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.uses-groups {
				display: grid;
				gap: 1.35rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.uses-group {
				display: grid;
				grid-template-columns: 180px minmax(0, 1fr);
				gap: 1.5rem;
				padding-top: 1.35rem;
				border-top: 1px solid rgba(var(--border), 0.8);
			}
			.uses-group:first-child {
				padding-top: 0;
				border-top: 0;
			}
			.uses-category {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.35;
			}
			.uses-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.85rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.uses-list li {
				min-width: 0;
				padding: 0.9rem 1rem;
				border: 1px solid rgba(var(--border), 0.86);
				border-radius: 8px;
				background: rgba(var(--surface-strong), 0.55);
			}
			.uses-name {
				display: inline-flex;
				color: rgb(var(--black));
				font-weight: 700;
				line-height: 1.35;
				text-decoration-color: rgba(var(--gray), 0.35);
				text-underline-offset: 0.18em;
			}
			.uses-name:hover {
				color: var(--accent);
			}
			.uses-description {
				margin: 0.45rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				line-height: 1.6;
			}
			.sns-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.sns-list a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.75rem;
				height: 2.75rem;
				border: 1px solid rgb(var(--border));
				border-radius: 50%;
				color: rgb(var(--black));
				background: rgba(var(--surface-strong), 0.75);
				text-decoration: none;
				transition:
					background-color 0.2s ease,
					border-color 0.2s ease,
					color 0.2s ease,
					transform 0.2s ease;
			}
			.sns-list a:hover {
				border-color: rgba(var(--accent-rgb), 0.55);
				background: rgba(var(--accent-rgb), 0.1);
				color: var(--accent);
				transform: translateY(-1px);
			}
			@media (max-width: 960px) {
				.profile-head {
					display: block;
				}
				.profile-meta {
					grid-template-columns: 4em minmax(0, 1fr);
					width: 100%;
					margin-top: 2rem;
					margin-left: 0;
					justify-self: stretch;
				}
				.meta-row dd {
					white-space: normal;
				}
			}
			@media (max-width: 820px) {
				.career-item,
				.highlights {
					display: block;
				}
				.name {
					font-size: 2.3rem;
				}
				.identity {
					align-items: flex-start;
					gap: 1rem;
				}
				.profile-photo {
					width: 72px;
					height: 72px;
				}
				.skill-groups {
					gap: 0;
				}
				.skill-group {
					display: block;
					padding: 1.25rem 0;
				}
				.skill-list {
					grid-template-columns: 1fr;
					margin-top: 0.85rem;
				}
				.uses-group {
					display: block;
				}
				.uses-list {
					grid-template-columns: 1fr;
					margin-top: 0.85rem;
				}
				.highlights li + li,
				.career-item + .career-item {
					margin-top: 1rem;
				}
				.period {
					margin-bottom: 0.3rem;
				}
			}
	</style>
		<main class="about-main">
			<article class="resume">
				<header class="profile-head">
					<div>
						<div class="identity">
							{
								heroImage && (
									<Image class="profile-photo" src={heroImage} alt={`${name} profile photo`} width={176} height={176} />
								)
							}
							<div>
								<h1 class="name">{name}</h1>
								<p class="role">{role}</p>
							</div>
						</div>
						<p class="summary">{description}</p>
					</div>
					<dl class="profile-meta">
						{age && (
							<div class="meta-row">
								<dt>年齢</dt>
								<dd>{age}</dd>
							</div>
						)}
						{location && (
							<div class="meta-row">
								<dt>所在地</dt>
								<dd>{location}</dd>
							</div>
						)}
						{company && (
							<div class="meta-row">
								<dt>所属</dt>
								<dd>{company}</dd>
							</div>
						)}
						{experience && (
							<div class="meta-row">
								<dt>経験年数</dt>
								<dd>{experience}</dd>
							</div>
						)}
					</dl>
				</header>

				{
					highlights.length > 0 && (
						<section class="resume-section" aria-labelledby="profile-heading">
							<h2 id="profile-heading" class="section-title">Profile</h2>
							<ul class="highlights">
								{highlights.map((highlight) => (
									<li>{highlight}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					skillGroups.length > 0 && (
						<section class="resume-section" aria-labelledby="skills-heading">
							<h2 id="skills-heading" class="section-title">Skills</h2>
							<ul class="skill-groups">
								{skillGroups.map((group) => (
									<li class="skill-group">
										<div class="skill-group-head">
											<h3 class="skill-category">{group.category}</h3>
										</div>
										<ul class="skill-list">
											{group.items.map((skill) => (
												<li>
													<span class="skill-name">{skill.name}</span>
													<span class="skill-years">{skill.years}</span>
												</li>
											))}
										</ul>
									</li>
								))}
							</ul>
						</section>
					)
				}

				{
					career.length > 0 && (
						<section class="resume-section" aria-labelledby="career-heading">
							<h2 id="career-heading" class="section-title">Career</h2>
							<div class="career-list">
								{career.map((item) => (
									<section class="career-item">
										<div class="period">{item.period}</div>
										<div class="career-body">
											<h3>{item.title}</h3>
											<p class="company">{item.company}</p>
											<p>{item.description}</p>
										</div>
									</section>
								))}
							</div>
						</section>
					)
					}

					{
						uses.length > 0 && (
							<section class="resume-section" aria-labelledby="uses-heading">
								<h2 id="uses-heading" class="section-title">Uses</h2>
								<ul class="uses-groups">
									{uses.map((group) => (
										<li class="uses-group">
											<h3 class="uses-category">{group.category}</h3>
											<ul class="uses-list">
												{group.items.map((item) => (
													<li>
														{
															item.url ? (
																<a class="uses-name" href={item.url} target="_blank" rel="noopener noreferrer">
																	{item.name}
																</a>
															) : (
																<span class="uses-name">{item.name}</span>
															)
														}
														<p class="uses-description">{item.description}</p>
													</li>
												))}
											</ul>
										</li>
									))}
								</ul>
							</section>
						)
					}

					{
						socials.length > 0 && (
							<section class="resume-section" aria-labelledby="details-heading">
								<h2 id="details-heading" class="section-title">Socials</h2>
							<ul class="sns-list">
								{socials.map((social) => (
									<li>
										<a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.label}>
											<Icon name={SOCIAL_ICON_NAMES[social.icon]} size={22} />
										</a>
									</li>
								))}
							</ul>
						</section>
					)
				}
			</article>
		</main>
</PageLayout>
