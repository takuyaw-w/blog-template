---
import { Image } from 'astro:assets';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BackLink from '../components/molecules/BackLink.astro';
import FormattedDate from '../components/atoms/FormattedDate.astro';
import { formatPostDate, getReadingTimeMinutes, toTaxonomySlug, type BlogPostEntry } from '../utils/blog';
import type { GitFileHistory } from '../utils/git-history';
import PageLayout from './PageLayout.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	headings?: MarkdownHeading[];
	readingTimeMinutes?: number;
	relatedPosts?: BlogPostEntry[];
	gitHistory?: GitFileHistory;
};

const MIN_TOC_HEADINGS = 3;
const MIN_TOC_READING_TIME_MINUTES = 5;

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	postId,
	tags = [],
	headings = [],
	readingTimeMinutes,
	relatedPosts = [],
	gitHistory = {},
} = Astro.props;
const tocHeadings = headings.filter(
	(heading) => heading.depth >= 2 && heading.depth <= 3 && heading.slug !== 'footnote-label',
);
const shouldShowTableOfContents =
	tocHeadings.length >= MIN_TOC_HEADINGS ||
	(readingTimeMinutes !== undefined && readingTimeMinutes >= MIN_TOC_READING_TIME_MINUTES);
const markdownUrl = postId ? `/blog/${postId}.md` : undefined;
const hasArticleInfo = tags.length > 0 || readingTimeMinutes !== undefined || category !== undefined;
const hasSidebar = hasArticleInfo || shouldShowTableOfContents;
const ogImage = postId ? new URL(`/og/${postId}.png`, Astro.site ?? Astro.url) : heroImage;
const publishedAt = gitHistory.publishedAt ?? pubDate;
const updatedAt = gitHistory.updatedAt ?? updatedDate;
const shouldShowUpdatedAt =
	updatedAt !== undefined && formatPostDate(updatedAt) !== formatPostDate(publishedAt);
---

<PageLayout title={title} description={description} image={ogImage}>
	<main class="w-[calc(var(--spacing-site-wide)+2em)] max-w-full">
		<BackLink href="/blog/" spacing="loose" />
		<article>
			<div
				class:list={[
					hasSidebar
						? 'grid w-full max-w-full grid-cols-[minmax(0,1040px)_300px] items-start gap-12 max-[980px]:block'
						: 'block w-full',
				]}
			>
				<div class="title col-span-full mx-auto mb-5 w-[1040px] max-w-full px-4 pt-4 text-center leading-none max-[720px]:px-2">
					<h1 class="mb-[0.5em] text-[clamp(1.875rem,3vw,2.5rem)] leading-[1.18] break-anywhere max-[480px]:text-[clamp(1.375rem,6vw,1.5rem)] max-[480px]:leading-[1.3]">
						{title}
					</h1>
					<hr />
				</div>
				{
					heroImage && (
						<Image
							class="col-span-full mx-auto mb-3 block aspect-[1200/630] w-full max-w-[1200px] rounded-xl object-cover max-[980px]:rounded-[10px]"
							width={1200}
							height={630}
							src={heroImage}
							alt=""
							loading="eager"
							decoding="sync"
							fetchpriority="high"
						/>
					)
				}
				{
					shouldShowTableOfContents && (
						<details class="table-of-contents hidden border-y border-site-border py-4 text-[0.9rem] leading-[1.4] max-[980px]:mx-4 max-[980px]:mb-4 max-[980px]:block max-[720px]:mx-2">
							<summary class="m-0 flex cursor-pointer list-none items-center justify-between text-[0.85rem] tracking-[0.04em] text-site-heading uppercase [&::-webkit-details-marker]:hidden">
								INDEX
							</summary>
							<ol class="m-0 list-none p-0">
								{tocHeadings.map((heading) => (
									<li class="mt-[0.45rem] first:mt-0">
										<a
											class:list={[
												'block rounded-r-md border-l-2 border-transparent py-1 pr-0 pl-[0.65rem] text-site-muted no-underline transition-colors duration-150 hover:text-site-accent',
												heading.depth === 3 && 'pl-[1.55rem]',
											]}
											href={`#${heading.slug}`}
										>
											{heading.text}
										</a>
									</li>
								))}
							</ol>
						</details>
					)
				}
				<div class:list={['p-4 text-site-text max-[720px]:px-2', !hasSidebar && 'mx-auto w-[1040px] max-w-full']}>
					<div class="prose prose-lg prose-blog">
						<slot />
						{
							markdownUrl && (
								<p class="mt-12 border-t border-site-border pt-5 text-[0.85rem] text-site-muted">
									Markdown source:{' '}
									<a
										class="text-site-text decoration-[rgba(var(--gray),0.35)] underline-offset-[0.18em] hover:text-site-accent"
										href={markdownUrl}
										rel="alternate"
										type="text/markdown"
									>
										{markdownUrl}
									</a>
								</p>
							)
						}
						{
							relatedPosts.length > 0 && (
								<section class="mt-12 border-t border-site-border pt-6" aria-labelledby="related-posts-heading">
									<h2 class="mt-0 mb-4 text-[1.1rem] tracking-normal" id="related-posts-heading">Related Posts</h2>
									<ul class="m-0 grid list-none grid-cols-3 gap-[0.85rem] p-0 max-[980px]:grid-cols-1">
										{relatedPosts.map((relatedPost) => (
											<li class="min-w-0">
												<a
													class="group flex min-h-full flex-col justify-between rounded-lg border border-[rgba(var(--border),0.86)] bg-[rgba(var(--surface-strong),0.62)] p-[0.9rem] text-inherit no-underline hover:border-[rgba(var(--accent-rgb),0.3)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[rgba(var(--accent-rgb),0.45)]"
													href={`/blog/${relatedPost.id}/`}
												>
													<span class="min-w-0">
														<span class="mb-[0.45rem] block text-[0.72rem] leading-[1.35] text-site-muted">
															{relatedPost.data.category} / {formatPostDate(relatedPost.data.pubDate)}
														</span>
														<span class="block text-base leading-[1.35] font-bold text-site-heading group-hover:text-site-text group-focus-visible:text-site-text">
															{relatedPost.data.title}
														</span>
														<span class="mt-1 block text-[0.8rem] leading-[1.5] text-site-muted">
															{relatedPost.data.description}
														</span>
													</span>
													<span class="mt-[0.9rem] block text-[0.78rem] leading-[1.4] text-site-muted">
														約{getReadingTimeMinutes(relatedPost.body)}分
													</span>
												</a>
											</li>
										))}
									</ul>
								</section>
							)
						}
					</div>
				</div>
				{
					hasSidebar && (
						<aside class="grid self-stretch grid-rows-[auto_1fr] gap-5 max-[980px]:static max-[980px]:mx-4 max-[720px]:mx-2" aria-label="Article sidebar">
							{hasArticleInfo && (
								<section
									class="border-b border-site-border py-4 text-[0.9rem] leading-[1.4] text-site-muted max-[980px]:border-t"
									aria-labelledby="article-info-heading"
								>
									<h2 class="mt-0 mb-3 text-[0.85rem] tracking-[0.04em] text-site-heading uppercase" id="article-info-heading">INFO</h2>
									<dl class="m-0 grid gap-[0.9rem]">
										<div>
											<dt class="mt-0 mb-[0.35rem] text-[0.8rem] font-bold text-site-heading">Published</dt>
											<dd class="m-0">
												<FormattedDate date={publishedAt} />
											</dd>
										</div>
										{shouldShowUpdatedAt && (
											<div>
												<dt class="mt-0 mb-[0.35rem] text-[0.8rem] font-bold text-site-heading">Updated</dt>
												<dd class="m-0">
													<FormattedDate date={updatedAt} />
												</dd>
											</div>
										)}
										{readingTimeMinutes !== undefined && (
											<div>
												<dt class="mt-0 mb-[0.35rem] text-[0.8rem] font-bold text-site-heading">Read time</dt>
												<dd class="m-0">約{readingTimeMinutes}分</dd>
											</div>
										)}
										{category !== undefined && (
											<div>
												<dt class="mt-0 mb-[0.35rem] text-[0.8rem] font-bold text-site-heading">Category</dt>
												<dd class="m-0">
													<a
														class="font-bold text-site-text decoration-[rgba(var(--gray),0.35)] underline-offset-[0.18em] hover:text-site-accent"
														href={`/categories/${toTaxonomySlug(category)}/`}
													>
														{category}
													</a>
												</dd>
											</div>
										)}
										{tags.length > 0 && (
											<div>
												<dt class="mt-0 mb-[0.35rem] text-[0.8rem] font-bold text-site-heading">Tags</dt>
												<dd class="m-0">
													<ul class="m-0 flex list-none flex-wrap gap-[0.45rem] p-0">
														{tags.map((tag) => (
															<li>
																<a
																	class="inline-flex min-h-[1.8rem] items-center rounded-full border border-[rgba(var(--border),0.9)] bg-[rgba(var(--surface-strong),0.72)] px-[0.55rem] py-[0.2rem] text-site-text no-underline hover:border-[rgba(var(--accent-rgb),0.45)] hover:text-site-accent"
																	href={`/tags/${toTaxonomySlug(tag)}/`}
																>
																	{tag}
																</a>
															</li>
														))}
													</ul>
												</dd>
											</div>
										)}
									</dl>
								</section>
							)}
							{shouldShowTableOfContents && (
								<details
									class="table-of-contents sticky top-6 self-start py-4 text-[0.9rem] leading-[1.4] max-[980px]:hidden"
									aria-label="Table of contents"
									open
								>
									<summary class="mb-3 block cursor-pointer list-none text-[0.85rem] tracking-[0.04em] text-site-heading uppercase [&::-webkit-details-marker]:hidden">
										INDEX
									</summary>
									<ol class="m-0 list-none p-0">
										{tocHeadings.map((heading) => (
											<li class="mt-[0.45rem] first:mt-0">
												<a
													class:list={[
														'block rounded-r-md border-l-2 border-transparent py-1 pr-0 pl-[0.65rem] text-site-muted no-underline transition-colors duration-150 hover:text-site-accent',
														heading.depth === 3 && 'pl-[1.55rem]',
													]}
													href={`#${heading.slug}`}
												>
													{heading.text}
												</a>
											</li>
										))}
									</ol>
								</details>
							)}
						</aside>
					)
				}
			</div>
		</article>
	</main>
		<script>
			(() => {
				const initActiveToc = () => {
					const tocLinks = Array.from(
						document.querySelectorAll('.table-of-contents a[href^="#"]'),
					);

					if (tocLinks.length === 0) {
						return;
					}

					const tocItems = tocLinks
						.map((link) => {
							const rawId = link.getAttribute('href')?.slice(1);

							if (!rawId) {
								return undefined;
							}

							let id = rawId;
							try {
								id = decodeURIComponent(rawId);
							} catch {
								// Keep the raw hash when it is not URI-encoded.
							}

							const target = document.getElementById(id);

							return target ? { id, link, target } : undefined;
						})
						.filter(Boolean);

					if (tocItems.length === 0) {
						return;
					}

					const setActiveHeading = (activeId) => {
						tocItems.forEach(({ id, link }) => {
							const isActive = id === activeId;
							link.classList.toggle('is-active', isActive);

							if (isActive) {
								link.setAttribute('aria-current', 'location');
							} else {
								link.removeAttribute('aria-current');
							}
						});
					};

					setActiveHeading(tocItems[0].id);

					const targetByElement = new Map(tocItems.map((item) => [item.target, item]));
					const observer = new IntersectionObserver(
						(entries) => {
							const activeEntry = entries
								.filter((entry) => entry.isIntersecting)
								.map((entry) => targetByElement.get(entry.target))
								.filter(Boolean)
								.at(-1);

							if (activeEntry) {
								setActiveHeading(activeEntry.id);
							}
						},
						{
							rootMargin: '-28% 0px -64% 0px',
							threshold: 0,
						},
					);

					tocItems.forEach(({ target }) => {
						observer.observe(target);
					});
				};

				initActiveToc();
			})();
		</script>
</PageLayout>
