{
  "name": "blog-template",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf dist .astro",
    "build": "astro build",
    "worker:dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "preview": "astro preview",
    "test:blog-title": "pnpm run build && playwright test tests/blog-title-responsive.spec.ts",
    "test:responsive": "pnpm run build && playwright test tests/blog-title-responsive.spec.ts tests/layout-responsive.spec.ts",
    "astro": "astro",
    "sync:content": "bash scripts/sync-content.sh",
    "build:with-content": "pnpm run clean && pnpm run sync:content && pnpm run build"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/transformers": "^4.2.0",
    "@tabler/icons": "^3.44.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.6",
    "linkedom": "^0.18.12",
    "mermaid": "^11.15.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^1.0.1",
    "@playwright/test": "^1.61.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
